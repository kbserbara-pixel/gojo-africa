# Quick local start (no Postgres/Redis needed):
# DATABASE_URL=sqlite:///./gojoafrica.db
#
# Supabase Postgres: Project Settings > Database > Connection string > URI,
# with your database password filled in. Direct connection (fine for a
# single FastAPI process):
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# Serverless deploys (many short-lived connections): use the Supavisor
# transaction pooler instead (note port 6543):
# DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:6543/postgres
#
# Supabase's "anon key" / "service role key" are for its REST API / client
# SDKs -- not used here, since this backend talks to Postgres directly via
# SQLAlchemy with its own auth system.

REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=
# Generate a real secret before deploying anywhere public, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
AWS_S3_BUCKET=gojo-africa-media
AWS_REGION=eu-west-1
ENVIRONMENT=development
# Comma-separated list of allowed frontend origins. Keep this to just your
# real domain(s) in production -- never "*" once the API is public.
CORS_ORIGINS=http://localhost:3000,https://gojo-africa.vercel.app
